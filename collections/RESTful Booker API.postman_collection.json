      "name": "01 Authentication",
      "item": [
        {
          "name": "Create Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let reponse = pm.response.json();\r",
                  "\r",
                  "pm.environment.set(\"token\", reponse.token);\r",
                  "\r",
                  "pm.test(\"Token is set\", function () {\r",
                  "    pm.expect(pm.environment.get(\"token\")).to.not.be.null;\r",
                  "    });\r",
                  "\r",
                  "\r",
                  "pm.test(\"GET booking returns status code 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    });"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\": \"{{adminname}}\",\r\n    \"password\": \"{{adminpassword}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseURL}}/auth",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "auth"
              ]
            },
            "description": "# **Create a token for hotel booking.**\n\n#### **Method:**\n\n- Post\n    \n\n#### **Expected response:**\n\n- 200 created\n    \n\n#### **Required fields:**\n\n- username\n    \n- password"
          },
          "response": []
        }
      ]
