        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200) \r",
                  "});\r",
                  "\r",
                  "let responseJson = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Booking ID is present\", function () {\r",
                  "    pm.expect(responseJson.bookingid).to.exist;\r",
                  "})\r",
                  "\r",
                  "pm.test(\"First name is John\", function () {\r",
                  "    pm.expect(responseJson.booking.firstname).to.eql(\"John\");\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Last name is Smith\", function () {\r",
                  "    pm.expect(responseJson.booking.lastname).to.eql(\"Smith\");\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Deposit is paid\", function () {\r",
                  "    pm.expect(responseJson.booking.depositpaid).to.eql(true);\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Total price is 150\", function () {\r",
                  "    pm.expect(responseJson.booking.totalprice).to.eql(150);\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Adddítional needs is breakfast\", function () {\r",
                  "    pm.expect(responseJson.booking.additionalneeds).to.eql(\"Breakfast\");\r",
                  "})\r",
                  "\r",
                  "pm.environment.set(\"bookingId\", responseJson.bookingid);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\": \"{{firstname}}\",\r\n    \"lastname\": \"{{lastname}}\",\r\n    \"totalprice\": 150,\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2026-08-01\",\r\n        \"checkout\": \"2026-08-05\"\r\n    },\r\n    \"additionalneeds\": \"Breakfast\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseURL}}/booking",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "booking"
              ]
            },
            "description": "# **Creates a new hotel booking.**\n\n#### **Method:**\n\n- Post\n    \n\n#### **Expected response:**\n\n- 200 created\n    \n\n#### **Required fields:**\n\n- firstname\n    \n- lastname\n    \n- totalprice\n    \n- depositpaid\n    \n- bookingdates\n    \n- additionalneeds"
